	"textMatch": {
		"matchRules": {
			"LLM-100%-indicators": {
				"query": [
					"ChatGPT (говори|сказа)[вл]",
					"ось аргументи на користь",
					"ось ваша стаття",
					"ось зміни відповідно до вашого",
					"ось оновлена та доповнена версія",
					"ось докладний аналіз",
					"ось( тобі)? (зміни|скоригований|текст)",
					"ви абсолютно",
					"ви можете",
					"ви цілком праві",
					"дайте мені знати",
					"для вашого запиту",
					"якщо хочете,? я можу",
					"як (адміністратор|редактор) (вікіпедії|української)",
					"на момент мого останнього",
					"нижче наведено (допо|виправ|оформ)",
					"за вашим запитом",
					"повідомте мені",
					"стил(і|ь|ю|ем) вікіпедії",
					"ти абсолютно правий",
					"я додав акценти"
				],
				"isRegExp": true,
				"title": "ШІ-текст",
				"message": "Цей текст створено великою мовною моделлю. Видаліть його або перепишіть із ретельною перевіркою.",
				"expand": "paragraph",
				"config": {
					"ignoreQuotedContent": true
				}
			},
			"autotranslation": {
				"query": [
					"приймати участь",
					"в кінці кінців",
					"слідуючий",
					"бувша у використанні"
				],
				"isRegExp": true,
				"title": "Неякісний переклад",
				"message": "Цей вислів, імовірно, є стилістичною помилкою. Будь ласка, виправте цю фразу, а також уважно перегляньте решту тексту статті на предмет невичитаного автоматичного перекладу або стилістичних недоліків.",
				"config": {
					"ignoreQuotedContent": true
				}
			},
			"autotranslation-is": {
				"query": [
					"(?\u003C!\\..*) — був",
					"(?\u003C!\\..*) — були"
				],
				"isRegExp": true,
				"title": "Неякісний переклад",
				"message": "Цей вислів, імовірно, є стилістичною помилкою. Будь ласка, виправте цю фразу, а також уважно перегляньте решту тексту статті на предмет невичитаного автоматичного перекладу або стилістичних недоліків.",
				"config": {
					"includeSections": [
						""
					]
				},
				"expand": "paragraph"
			},
			"nonneutral-comments": {
				"query": [
					"(відом|видатн|геніальн)[а-яёєії]+ (письм|вчен|режисер|поет|спортсмен|[а-яёєії]+іст)[а-яёєії]{0,4}",
					"(важливо|треба) відзначити",
					"(багато|деякі) вважають",
					"як кажуть (лікар|спеціаліст|старожил|вчен|фізик|хімік)[а-яёєії]{0,2}",
					"велик[а-яёєії]+ майстер[а-яёєії]* свого",
					"захис[а-яёєії]+ батьківщ[а-яёєії]+",
					"на (щастя|жаль),?( для)? на[а-яёєії]+"
				],
				"isRegExp": true,
				"title": "Неенциклопедичне формулювання",
				"message": "Цей вислів, імовірно, містить неенциклопедичне або ненейтральне формулювання. Перевірте його та за потреби перепишіть, вилучивши оціночні твердження.",
				"config": {
					"ignoreQuotedContent": true
				}
			},
			"nonspecific-time": {
				"query": [
					"(в|у|на) (цей|даний|сьогодн|наш)[а-яёєії]{0,2} (момент|період|час|дні)"
				],
				"isRegExp": true,
				"title": "Невизначений час",
				"message": "Цей вислів, імовірно, містить вказівку на невизначений час. Важливо враховувати, що інформація швидко застаріває, тому слід надавати читачеві конкретну часову прив’язку — указувати рік, десятиліття або століття, до якого належить факт.",
				"config": {
					"ignoreQuotedContent": true
				}
			},
			"first-person-pronouns": {
				"query": [
					"я вважаю"
				],
				"isRegExp": true,
				"title": "Перевірити формулювання",
				"message": "Речення використовує займенники першої особи та може будти особистою думкою. Видаліть або переформулюйте його за потреби.",
				"config": {
					"ignoreQuotedContent": true,
					"ignoreDisambiguationPages": true,
					"showAsCheck": false,
					"showAsSuggestion": false
				}
			},
			"long-paragraph": {
				"query": [
					".{2000,}"
				],
				"isRegExp": true,
				"title": "Довгий абзац",
				"message": "Абзац надто довгий. Розділіть його на кілька абзаців або суттєво скоротіть.",
				"expand": "paragraph"
			},
			"tautology": {
				"query": [
					"народн[а-я]+ фольклор[а-я]+",
					"перш[а-я]+ дебют[а-я]+"
				],
				"isRegExp": true,
				"title": "Тавтологія",
				"message": "У цьому виразі може міститися стилістична помилка, що полягає в надмірному повторенні. Допоможіть виправити текст, усунувши [[тавтологія|тавтологію]] або [[плеоназм]]",
				"config": {
					"ignoreQuotedContent": true
				}
			},
			"tautology-test": {
				"query": [
					"([а-яёєії]+)іст[а-яёєії]*,?( и)?( (воротар|захисн|півзахиснік|нападн|вінгер|грав)[а-яёєії]*)? \\1[а-я]+ клубу"
				],
				"isRegExp": true,
				"title": "Тавтологія",
				"message": "У цьому виразі може міститися стилістична помилка, що полягає в надмірному повторенні. Допоможіть виправити текст, усунувши [[тавтологія|тавтологію]] або [[плеоназм]]",
				"config": {
					"ignoreQuotedContent": true
				}
			},
			"tautology-full": {
				"query": [
					"([а-яёєії]{5})[а-яёєії]* \\1[а-яёєії]*"
				],
				"isRegExp": true,
				"title": "Тавтологія",
				"message": "У цьому виразі може міститися стилістична помилка, що полягає в надмірному повторенні. Допоможіть виправити текст, усунувши [[тавтологія|тавтологію]] або [[плеоназм]]",
				"config": {
					"caseSensitive": true,
					"ignoreQuotedContent": true
				}
			},
			"nonreliable-source": {
				"query": [
					"за (даними|інформації) (anna news|daily mail|dialog\\.ua|eadaily|eurasia daily|informnapalm|rt|rubaltic\\.ru|ruptly|russia today|the moscow post|eva\\.ru|fedpress\\.ru|mirsegodnya\\.com|ruskino\\.ru|sudogda\\.ru|topwar\\.ru|wellnesso\\.ru|царьград тв|([а-яёєії]+ )?вікіпедії)"
				],
				"isRegExp": true,
				"title": "Небажане джерело",
				"message": "Це джерело є неавторитетним і небажаним для використання у статтях Вікіпедії. Перевірте доцільність його використання та за потреби замініть його більш авторитетним джерелом.",
				"config": {
					"ignoreQuotedContent": true
				}
			},
			"broken-source": {
				"query": [
					"\\[\\d+\\][.,]",
					"[.,]\\[\\d+\\]"
				],
				"isRegExp": true,
				"title": "Неправильне оформлення джерела",
				"message": "Це оформлення джерел є неправильним. Будь ласка, допоможіть читачам і оформіть посилання коректно, натиснувши кнопку «Джерело» на верхній панелі.",
				"config": {
					"ignoreSections": []
				}
			}
		}
	}
